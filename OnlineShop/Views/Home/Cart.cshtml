@model List<Product>
@{
    ViewData["Title"] = "Cart";
}

<h2 class="text-center text-info my-4">Your Cart</h2>

@if (Model.Count == 0)
{
    <div class="alert alert-warning text-center" role="alert">
        <h4>Your cart is empty!</h4>
        <a asp-action="Index" asp-controller="Home" class="btn btn-primary mt-3">Continue Shopping</a>
    </div>
}
else
{
    <div class="container mb-5">
        <div class="table-responsive" style="max-height: 70vh; overflow-y: auto;">
            <table class="table table-bordered table-hover align-middle shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Price</th>
                        <th>Quantity</th>

                        <th>Product Type</th>
                        <th>Color</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="~/files/images/@item.Image" width="200px" height="150px" />
                            </td>
                            <td>@item.Name</td>
                            <td>$@item.Price.ToString("0.00")</td>
                            <td>@item.Quantity</td>
                            <td>@item.ProductType?.Name </td>
                            <td>@item.ProductColor</td>
                            <td class="text-center">
                                <a asp-action="Remove" asp-controller="Home" asp-route-id="@item.Id" class="btn btn-danger">
                                    <i class="fas fa-trash-alt"></i> Remove
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-4">
            <div class="col-md-6">
                <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Home
                </a>
            </div>
            <div class="col-md-6 text-end">
                <h4 class="text-muted">Total Amount</h4>
                <h3 class="text-success">Grand Total: $@Model.Sum(e => e.Price*e.Quantity).ToString("0.00")</h3>
                <a asp-action="Checkout" asp-controller="Order" class="btn btn-info mt-3">
                    <i class="fas fa-credit-card"></i> Proceed to Checkout
                </a>
            </div>
        </div>
    </div>
}




 