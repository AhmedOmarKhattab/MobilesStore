<style>
    @@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800;900&family=Tajawal:wght@300;400;500;700;800&display=swap');

    :root {
        --primary: #6c63ff;
        --primary-dark: #4f46e5;
        --accent: #ff6b6b;
        --gold: #f59e0b;
        --green: #10b981;
        --dark: #0d1117;
        --card-bg: #ffffff;
        --text: #1f2937;
        --text-muted: #6b7280;
        --border-r: 16px;
        --transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * {
        box-sizing: border-box;
    }

    body {
        background: #f8f9ff;
        font-family: 'Cairo', 'Tajawal', sans-serif;
        direction: rtl;
    }

    /* ─── HERO ─── */
    .hero-section {
        position: relative;
        height: 85vh;
        min-height: 520px;
        overflow: hidden;
    }

    .hero-slides {
        width: 100%;
        height: 100%;
    }

    .hero-slide {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.8s ease;
        pointer-events: none;
    }

        .hero-slide.active {
            opacity: 1;
            pointer-events: all;
        }

    .slide-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1100px;
        width: 100%;
        padding: 2rem;
        gap: 3rem;
        flex-direction: row-reverse;
    }

    .slide-text {
        flex: 1;
        color: white;
        text-align: right;
    }

    .slide-tag {
        display: inline-block;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.9);
        padding: 0.4rem 1.2rem;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
        border: 1px solid rgba(255,255,255,0.2);
        margin-bottom: 1.2rem;
        letter-spacing: 0.03em;
    }

    .hero-title {
        font-family: 'Cairo', sans-serif;
        font-size: clamp(2rem, 4vw, 3.2rem);
        font-weight: 900;
        line-height: 1.2;
        margin-bottom: 1rem;
        text-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .accent-text {
        color: #a78bfa;
    }

        .accent-text.gold {
            color: var(--gold);
        }

        .accent-text.green {
            color: #34d399;
        }

    .hero-sub {
        font-size: 1.05rem;
        opacity: 0.85;
        margin-bottom: 2rem;
        font-weight: 400;
        max-width: 380px;
        margin-right: 0;
        margin-left: auto;
    }

    .hero-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        padding: 0.9rem 2rem;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 700;
        font-size: 1rem;
        transition: var(--transition);
        box-shadow: 0 10px 30px rgba(108,99,255,0.4);
    }

        .hero-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 16px 40px rgba(108,99,255,0.5);
            color: white;
        }

    .gold-btn {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        box-shadow: 0 10px 30px rgba(245,158,11,0.4);
    }

        .gold-btn:hover {
            box-shadow: 0 16px 40px rgba(245,158,11,0.5);
            color: white;
        }

    .green-btn {
        background: linear-gradient(135deg, #10b981, #059669);
        box-shadow: 0 10px 30px rgba(16,185,129,0.4);
    }

        .green-btn:hover {
            box-shadow: 0 16px 40px rgba(16,185,129,0.5);
            color: white;
        }

    .btn-arrow {
        font-size: 1.1rem;
    }

    /* Phone Mockup */
    .slide-device {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .phone-mockup {
        width: 160px;
        height: 300px;
        background: linear-gradient(145deg, #1e1e2e, #2d2d3f);
        border-radius: 36px;
        border: 6px solid rgba(255,255,255,0.15);
        position: relative;
        box-shadow: 0 30px 80px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.1);
        animation: floatDevice 3s ease-in-out infinite;
    }

    .phone-screen {
        width: 100%;
        height: 100%;
        background: linear-gradient(145deg, #0f0f1a, #1a1a2e);
        border-radius: 30px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1rem 0.75rem 0.75rem;
    }

    .phone-notch {
        width: 50px;
        height: 12px;
        background: #000;
        border-radius: 0 0 8px 8px;
        margin-bottom: 1rem;
    }

    .phone-inner {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .phone-line {
        height: 8px;
        background: rgba(108,99,255,0.5);
        border-radius: 4px;
    }

        .phone-line.short {
            width: 60%;
        }

    .phone-glow {
        position: absolute;
        width: 200px;
        height: 200px;
        background: radial-gradient(circle, rgba(108,99,255,0.4) 0%, transparent 70%);
        border-radius: 50%;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: -1;
    }

    /* Tablet Mockup */
    .tablet-mockup {
        width: 240px;
        height: 180px;
        background: linear-gradient(145deg, #1e1e2e, #2d2d3f);
        border-radius: 20px;
        border: 5px solid rgba(255,255,255,0.15);
        box-shadow: 0 30px 80px rgba(0,0,0,0.6);
        animation: floatDevice 3s ease-in-out infinite;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .tablet-screen {
        width: 90%;
        height: 85%;
        background: linear-gradient(145deg, #0f0f1a, #1a1a2e);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .tablet-inner {
        font-size: 3rem;
        animation: pulse 2s ease infinite;
    }

    /* Watch Mockup */
    .watch-mockup {
        width: 130px;
        height: 150px;
        background: linear-gradient(145deg, #1e1e2e, #2d2d3f);
        border-radius: 32px;
        border: 5px solid rgba(255,255,255,0.15);
        box-shadow: 0 30px 80px rgba(0,0,0,0.6);
        animation: floatDevice 3s ease-in-out infinite;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .watch-screen {
        width: 85%;
        height: 85%;
        background: linear-gradient(145deg, #0a0a14, #111122);
        border-radius: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .watch-time {
        color: #34d399;
        font-size: 1.5rem;
        font-weight: 700;
        font-family: monospace;
    }

    .device-glow {
        position: absolute;
        width: 250px;
        height: 250px;
        border-radius: 50%;
        z-index: -1;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

        .device-glow.blue {
            background: radial-gradient(circle, rgba(59,130,246,0.35) 0%, transparent 70%);
        }

        .device-glow.green {
            background: radial-gradient(circle, rgba(16,185,129,0.35) 0%, transparent 70%);
        }

    @@keyframes floatDevice {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-15px);
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.1);
        }
    }

    /* Slide Dots */
    .slide-dots {
        position: absolute;
        bottom: 2.5rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 0.6rem;
        z-index: 10;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255,255,255,0.4);
        border: none;
        cursor: pointer;
        transition: var(--transition);
    }

        .dot.active {
            background: white;
            width: 28px;
            border-radius: 5px;
        }

    /* Scroll indicator */
    .hero-scroll-indicator {
        position: absolute;
        bottom: 4.5rem;
        left: 50%;
        transform: translateX(-50%);
        color: white;
        font-size: 1.8rem;
        animation: bounce 2s infinite;
        opacity: 0.6;
        z-index: 5;
    }

    @@keyframes bounce {
        0%, 100% {
