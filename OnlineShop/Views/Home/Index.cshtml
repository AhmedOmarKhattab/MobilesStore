@model X.PagedList.IPagedList<Product>
@{
    ViewData["Title"] = "الصفحة الرئيسية";
}

<!-- Hero Section - Mobile Store -->
<div class="hero-section" dir="rtl">
    <div class="hero-slides">
        <div class="hero-slide active" style="background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);">
            <div class="slide-content">
                <div class="slide-device">
                    <div class="phone-mockup">
                        <div class="phone-screen">
                            <div class="phone-notch"></div>
                            <div class="phone-inner">
                                <div class="phone-line"></div>
                                <div class="phone-line short"></div>
                                <div class="phone-line"></div>
                            </div>
                        </div>
                    </div>
                    <div class="phone-glow"></div>
                </div>
                <div class="slide-text">
                    <span class="slide-tag">الأحدث في السوق</span>
                    <h1 class="hero-title">هواتف ذكية<br /><span class="accent-text">بتقنية خارقة</span></h1>
                    <p class="hero-sub">اكتشف أحدث الهواتف الذكية بأسعار لا تُقاوم</p>
                    <a href="#products" class="hero-btn">تسوّق الآن <span class="btn-arrow">←</span></a>
                </div>
            </div>
        </div>
        <div class="hero-slide" style="background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460);">
            <div class="slide-content">
                <div class="slide-device">
                    <div class="tablet-mockup">
                        <div class="tablet-screen">
                            <div class="tablet-inner">
                                <div class="tablet-icon">📱</div>
                            </div>
                        </div>
                    </div>
                    <div class="device-glow blue"></div>
                </div>
                <div class="slide-text">
                    <span class="slide-tag">عروض حصرية</span>
                    <h1 class="hero-title">إكسسوارات<br /><span class="accent-text gold">بجودة عالية</span></h1>
                    <p class="hero-sub">سماعات، شواحن، وكفرات لجميع الأجهزة</p>
                    <a href="#products" class="hero-btn gold-btn">استكشف الآن <span class="btn-arrow">←</span></a>
                </div>
            </div>
        </div>
        <div class="hero-slide" style="background: linear-gradient(135deg, #0d1117, #161b22, #1c2128);">
            <div class="slide-content">
                <div class="slide-device">
                    <div class="watch-mockup">
                        <div class="watch-screen">
                            <div class="watch-time">10:09</div>
                        </div>
                    </div>
                    <div class="device-glow green"></div>
                </div>
                <div class="slide-text">
                    <span class="slide-tag">جديد لدينا</span>
                    <h1 class="hero-title">ساعات ذكية<br /><span class="accent-text green">للحياة العصرية</span></h1>
                    <p class="hero-sub">ابقَ متصلاً ومتابعاً لصحتك على مدار اليوم</p>
                    <a href="#products" class="hero-btn green-btn">اكتشف الآن <span class="btn-arrow">←</span></a>
                </div>
            </div>
        </div>
    </div>

    <!-- Slide Indicators -->
    <div class="slide-dots">
        <button class="dot active" onclick="goToSlide(0)"></button>
        <button class="dot" onclick="goToSlide(1)"></button>
        <button class="dot" onclick="goToSlide(2)"></button>
    </div>

    <div class="hero-scroll-indicator">
        <i class="bi bi-chevron-down"></i>
    </div>
</div>

<!-- Stats Bar -->
<div class="stats-bar">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item">
                <span class="stat-number">+٥٠٠٠</span>
                <span class="stat-label">منتج متوفر</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-number">+١٠٠٠٠</span>
                <span class="stat-label">عميل راضٍ</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-number">٢٤/٧</span>
                <span class="stat-label">دعم فني</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-number">مجاني</span>
                <span class="stat-label">شحن للطلبات +٢٠٠$</span>
            </div>
        </div>
    </div>
</div>

<!-- Shop by Category -->
<div class="container my-5" dir="rtl">
    <div class="section-header text-center mb-4">
        <h2 class="section-title">تسوّق حسب الفئة</h2>
        <div class="title-underline"></div>
    </div>
    <div class="row g-3">
        <div class="col-4">
            <div class="category-card">
                <i class="bi bi-phone category-icon"></i>
                <p class="category-name">الهواتف الذكية</p>
            </div>
        </div>
        <div class="col-4">
            <div class="category-card">
                <i class="bi bi-headphones category-icon"></i>
                <p class="category-name">الإكسسوارات</p>
            </div>
        </div>
        <div class="col-4">
            <div class="category-card">
                <i class="bi bi-smartwatch category-icon"></i>
                <p class="category-name">الساعات الذكية</p>
            </div>
        </div>
    </div>
</div>

<!-- Products Section -->
<div id="products" class="container my-5" dir="rtl">
    <div class="section-header text-center mb-4">
        <h2 class="section-title">المنتجات المميزة</h2>
        <div class="title-underline"></div>
        <p class="text-muted mt-2">تصفّح أحدث مجموعاتنا</p>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-bag-x empty-icon"></i>
            <h3 class="empty-title">لا توجد منتجات متاحة</h3>
            <p class="empty-text">تفقّد الصفحة لاحقاً لمنتجات جديدة ومثيرة!</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in Model)
            {
                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="product-card">
                        <div class="product-image-wrapper">
                            <img src="~/files/images/@product.Image"
                                 alt="@product.Name"
                                 class="product-image"
                                 loading="lazy" />
                            @if (product.Quantity < 10)
                            {
                                <span class="product-badge badge-warning">كمية محدودة</span>
                            }
                            @if (product.Price < 50)
                            {
                                <span class="product-badge badge-sale">تخفيض</span>
                            }
                        </div>
                        <div class="product-body">
                            <h5 class="product-title">@product.Name</h5>
                            <div class="product-rating mb-2">
                                <i class="bi bi-star-fill text-warning"></i>
                                <i class="bi bi-star-fill text-warning"></i>
                                <i class="bi bi-star-fill text-warning"></i>
                                <i class="bi bi-star-fill text-warning"></i>
                                <i class="bi bi-star-half text-warning"></i>
                                <span class="ms-1 text-muted small">(٤.٥)</span>
                            </div>
                            <div class="product-meta">
                                <div class="product-price">
                                    <span class="price-current">$@product.Price.ToString("0.00")</span>
                                </div>
                                <div class="product-stock">
                                    <i class="bi bi-box-seam"></i>
                                    <span>@product.Quantity في المخزون</span>
                                </div>
                            </div>
                            <a asp-action="Details"
                               asp-controller="Home"
                               asp-route-id="@product.Id"
                               class="product-btn">
                                <i class="bi bi-eye me-2"></i>عرض التفاصيل
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="pagination-wrapper">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions
            {
                DisplayLinkToFirstPage = PagedListDisplayMode.Never,
                DisplayLinkToLastPage = PagedListDisplayMode.Never,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,
                LinkToPreviousPageFormat = "→ السابق",
                LinkToNextPageFormat = "التالي ←",
                UlElementClasses = new[] { "pagination-custom" },
                LiElementClasses = new[] { "page-item-custom" }
                })
    </div>
        }
</div>

<!-- Newsletter Section -->
<div class="newsletter-section" dir="rtl">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h3 class="newsletter-title">ابقَ على اطلاع دائم</h3>
                <p class="newsletter-text">اشترك للحصول على عروض خاصة وآخر الأخبار</p>
            </div>
            <div class="col-lg-6">
                <div class="newsletter-form">
                    <button class="btn newsletter-btn">
                        <i class="bi bi-send-fill"></i>
                    </button>
                    <input type="email" class="form-control newsletter-input" placeholder="أدخل بريدك الإلكتروني">
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800;900&family=Tajawal:wght@300;400;500;700;800&display=swap');

    :root {
        --primary: #6c63ff;
        --primary-dark: #4f46e5;
        --accent: #ff6b6b;
        --gold: #f59e0b;
        --green: #10b981;
        --dark: #0d1117;
        --card-bg: #ffffff;
        --text: #1f2937;
        --text-muted: #6b7280;
        --border-r: 16px;
        --transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * {
        box-sizing: border-box;
    }

    body {
        background: #f8f9ff;
        font-family: 'Cairo', 'Tajawal', sans-serif;
        direction: rtl;
    }

    /* ─── HERO ─── */
    .hero-section {
        position: relative;
        height: 85vh;
        min-height: 520px;
        overflow: hidden;
    }

    .hero-slides {
        width: 100%;
        height: 100%;
    }

    .hero-slide {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.8s ease;
        pointer-events: none;
    }

        .hero-slide.active {
            opacity: 1;
            pointer-events: all;
        }

    .slide-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1100px;
        width: 100%;
        padding: 2rem;
        gap: 3rem;
        flex-direction: row-reverse;
    }

    .slide-text {
        flex: 1;
        color: white;
        text-align: right;
    }

    .slide-tag {
        display: inline-block;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.9);
        padding: 0.4rem 1.2rem;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
        border: 1px solid rgba(255,255,255,0.2);
        margin-bottom: 1.2rem;
        letter-spacing: 0.03em;
    }

    .hero-title {
        font-family: 'Cairo', sans-serif;
        font-size: clamp(2rem, 4vw, 3.2rem);
        font-weight: 900;
        line-height: 1.2;
        margin-bottom: 1rem;
        text-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .accent-text {
        color: #a78bfa;
    }

        .accent-text.gold {
            color: var(--gold);
        }

        .accent-text.green {
            color: #34d399;
        }

    .hero-sub {
        font-size: 1.05rem;
        opacity: 0.85;
        margin-bottom: 2rem;
        font-weight: 400;
        max-width: 380px;
        margin-right: 0;
        margin-left: auto;
    }

    .hero-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        padding: 0.9rem 2rem;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 700;
        font-size: 1rem;
        transition: var(--transition);
        box-shadow: 0 10px 30px rgba(108,99,255,0.4);
    }

        .hero-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 16px 40px rgba(108,99,255,0.5);
            color: white;
        }

    .gold-btn {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        box-shadow: 0 10px 30px rgba(245,158,11,0.4);
    }

        .gold-btn:hover {
            box-shadow: 0 16px 40px rgba(245,158,11,0.5);
            color: white;
        }

    .green-btn {
        background: linear-gradient(135deg, #10b981, #059669);
        box-shadow: 0 10px 30px rgba(16,185,129,0.4);
    }

        .green-btn:hover {
            box-shadow: 0 16px 40px rgba(16,185,129,0.5);
            color: white;
        }

    .btn-arrow {
        font-size: 1.1rem;
    }

    /* Phone Mockup */
    .slide-device {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .phone-mockup {
        width: 160px;
        height: 300px;
        background: linear-gradient(145deg, #1e1e2e, #2d2d3f);
        border-radius: 36px;
        border: 6px solid rgba(255,255,255,0.15);
        position: relative;
        box-shadow: 0 30px 80px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.1);
        animation: floatDevice 3s ease-in-out infinite;
    }

    .phone-screen {
        width: 100%;
        height: 100%;
        background: linear-gradient(145deg, #0f0f1a, #1a1a2e);
        border-radius: 30px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1rem 0.75rem 0.75rem;
    }

    .phone-notch {
        width: 50px;
        height: 12px;
        background: #000;
        border-radius: 0 0 8px 8px;
        margin-bottom: 1rem;
    }

    .phone-inner {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .phone-line {
        height: 8px;
        background: rgba(108,99,255,0.5);
        border-radius: 4px;
    }

        .phone-line.short {
            width: 60%;
        }

    .phone-glow {
        position: absolute;
        width: 200px;
        height: 200px;
        background: radial-gradient(circle, rgba(108,99,255,0.4) 0%, transparent 70%);
        border-radius: 50%;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: -1;
    }

    /* Tablet Mockup */
    .tablet-mockup {
        width: 240px;
        height: 180px;
        background: linear-gradient(145deg, #1e1e2e, #2d2d3f);
        border-radius: 20px;
        border: 5px solid rgba(255,255,255,0.15);
        box-shadow: 0 30px 80px rgba(0,0,0,0.6);
        animation: floatDevice 3s ease-in-out infinite;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .tablet-screen {
        width: 90%;
        height: 85%;
        background: linear-gradient(145deg, #0f0f1a, #1a1a2e);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .tablet-inner {
        font-size: 3rem;
        animation: pulse 2s ease infinite;
    }

    /* Watch Mockup */
    .watch-mockup {
        width: 130px;
        height: 150px;
        background: linear-gradient(145deg, #1e1e2e, #2d2d3f);
        border-radius: 32px;
        border: 5px solid rgba(255,255,255,0.15);
        box-shadow: 0 30px 80px rgba(0,0,0,0.6);
        animation: floatDevice 3s ease-in-out infinite;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .watch-screen {
        width: 85%;
        height: 85%;
        background: linear-gradient(145deg, #0a0a14, #111122);
        border-radius: 26px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .watch-time {
        color: #34d399;
        font-size: 1.5rem;
        font-weight: 700;
        font-family: monospace;
    }

    .device-glow {
        position: absolute;
        width: 250px;
        height: 250px;
        border-radius: 50%;
        z-index: -1;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

        .device-glow.blue {
            background: radial-gradient(circle, rgba(59,130,246,0.35) 0%, transparent 70%);
        }

        .device-glow.green {
            background: radial-gradient(circle, rgba(16,185,129,0.35) 0%, transparent 70%);
        }

    @@keyframes floatDevice {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-15px);
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.1);
        }
    }

    /* Slide Dots */
    .slide-dots {
        position: absolute;
        bottom: 2.5rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 0.6rem;
        z-index: 10;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255,255,255,0.4);
        border: none;
        cursor: pointer;
        transition: var(--transition);
    }

        .dot.active {
            background: white;
            width: 28px;
            border-radius: 5px;
        }

    /* Scroll indicator */
    .hero-scroll-indicator {
        position: absolute;
        bottom: 4.5rem;
        left: 50%;
        transform: translateX(-50%);
        color: white;
        font-size: 1.8rem;
        animation: bounce 2s infinite;
        opacity: 0.6;
        z-index: 5;
    }

    @@keyframes bounce {
        0%, 100% {
            transform: translateX(-50%) translateY(0);
        }

        40% {
            transform: translateX(-50%) translateY(-10px);
        }

        60% {
            transform: translateX(-50%) translateY(-5px);
        }
    }

    /* ─── STATS BAR ─── */
    .stats-bar {
        background: white;
        padding: 1.5rem 0;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    }

    .stats-grid {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        flex-wrap: wrap;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0.75rem 2.5rem;
        gap: 0.2rem;
    }

    .stat-number {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--primary);
        font-family: 'Cairo', sans-serif;
    }

    .stat-label {
        font-size: 0.8rem;
        color: var(--text-muted);
        font-weight: 500;
    }

    .stat-divider {
        width: 1px;
        height: 40px;
        background: #e5e7eb;
    }

    /* ─── SECTION HEADERS ─── */
    .section-title {
        font-family: 'Cairo', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 0.5rem;
    }

    .title-underline {
        width: 60px;
        height: 4px;
        background: linear-gradient(90deg, var(--primary), #a78bfa);
        margin: 0 auto;
        border-radius: 2px;
    }

    /* ─── CATEGORY CARDS ─── */
    .category-card {
        background: white;
        border-radius: var(--border-r);
        padding: 1.5rem 1rem;
        text-align: center;
        transition: var(--transition);
        cursor: pointer;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
        border: 2px solid transparent;
    }

        .category-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(108,99,255,0.15);
            border-color: rgba(108,99,255,0.2);
        }

    .category-icon {
        font-size: 2.5rem;
        color: var(--primary);
        margin-bottom: 0.5rem;
        display: block;
    }

    .category-name {
        margin: 0;
        font-weight: 700;
        color: var(--text);
        font-size: 0.9rem;
    }

    /* ─── PRODUCT CARDS ─── */
    .product-card {
        background: white;
        border-radius: var(--border-r);
        overflow: hidden;
        transition: var(--transition);
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        height: 100%;
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(0,0,0,0.04);
    }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(108,99,255,0.12);
        }

    .product-image-wrapper {
        position: relative;
        overflow: hidden;
        padding-top: 100%;
        background: #f3f4f6;
    }

    .product-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: var(--transition);
    }

    .product-card:hover .product-image {
        transform: scale(1.06);
    }

    .product-badge {
        position: absolute;
        top: 1rem;
        left: 1rem;
        padding: 0.4rem 0.9rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        z-index: 1;
    }

    .badge-warning {
        background: var(--gold);
        color: white;
    }

    .badge-sale {
        background: #ef4444;
        color: white;
        top: 3.5rem;
    }

    .product-body {
        padding: 1.25rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .product-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 0.5rem;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .product-rating {
        font-size: 0.9rem;
    }

    .price-current {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--primary);
    }

    .product-stock {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-muted);
        font-size: 0.85rem;
