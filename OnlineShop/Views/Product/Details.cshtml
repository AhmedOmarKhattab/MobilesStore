@model Product
@{
    ViewData["Title"] = "Details";
}

<h2 class="text-info">Product Details</h2>
<form asp-controller="Product" asp-action="Details" method="post" enctype="multipart/form-data">
    <div class="p-4 rounded border row">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-8">
            <input type="hidden" asp-for="Id" />

            <div class="form-group row mb-3">
                <div class="col-4"><label asp-for="Name"></label></div>
                <div class="col-8">
                    <input asp-for="Name" readonly="readonly"  class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row mb-3">
                <div class="col-4"><label asp-for="Price"></label></div>
                <div class="col-8">
                    <input asp-for="Price" readonly="readonly" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group row mb-3">
                <div class="col-4"><label asp-for="Description"></label></div>
                <div class="col-8">
                    <input asp-for="Description" readonly="readonly" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>
            <div class="col-4"><label asp-for="Quantity"></label></div>
                <div class="col-8">
                    <input asp-for="Quantity" readonly="readonly" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>
            </div>


            <div class="form-group row mb-3">
                <div class="col-4"><label asp-for="ProductColor"></label></div>
                <div class="col-8">
                    <input asp-for="ProductColor" readonly="readonly" class="form-control" />
                    <span asp-validation-for="ProductColor" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row mb-3 d-none">
                <div class="col-4"><label asp-for="ProductTypeId"></label></div>
                <div class="col-8">
                    @* <select asp-for="ProductTypeId" asp-items="ViewBag.productTypeId" class="form-control"></select> *@
                    <input asp-for="ProductTypeId" readonly="readonly" class="form-control" />
                    <span asp-validation-for="ProductTypeId" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group row mb-3 ">
                <div class="col-4"><label asp-for="ProductTypeId"></label></div>
                <div class="col-8">
                    @* <select asp-for="ProductTypeId" asp-items="ViewBag.productTypeId" class="form-control"></select> *@
                    <input  readonly="readonly" value="@Model.ProductType.Name" class="form-control" />
                </div>
            </div>
            <div class="form-group row mb-3">
                <div class="col-4"><label asp-for="SpecialTagId"></label></div>
                <div class="col-8">
                   @*  <select asp-for="SpecialTagId" asp-items="ViewBag.TagId" class="form-control"></select> *@
                    <input asp-for="SpecialTagId" readonly="readonly" class="form-control" />
                    <span asp-validation-for="SpecialTagId" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row mb-3">
                <div class="col-4"><label asp-for="IsAvailable"></label></div>
                <div class="col-8">
                    <input asp-for="IsAvailable" readonly="readonly" type="checkbox" />
                    <span asp-validation-for="IsAvailable" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
                <a asp-action="Index" class="btn btn-success">Back to List</a>
            </div>
        </div>

        <div class="col-md-4 text-center">
            <img src="~/files/images/@(Model.Image ?? "noimage.png")" class="img-thumbnail" width="200" />
            <p>No Image Found</p>
        </div>
    </div>
</form>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
