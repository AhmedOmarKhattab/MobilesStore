@model IEnumerable<Product>
@{
    ViewData["Title"] = "Index";
}
<br />
<br />
 
<div class="row">
    <div class="col-6">
        <h2 class="text-info">Product List</h2>
    </div>
    <div class="col-6 text-right">
        <a asp-action="Create" class="btn btn-info">
            <i class="fa fa-plus"></i>Add New Product
        </a>
    </div>
</div>
<form method="post">
    <div class="row">
        <div class="col-3">
            <input type="number" class="form-control" name="lowAmount" placeholder="Low Amount" />
        </div>
        <div class="col-3">
            <input type="number" class="form-control" name="highAmount" placeholder="High Amount" />
        </div>
        <div class="col-3">
            <input type="submit" value="Search"class="btn btn-success" />
        </div>
        <div class="col-3"></div>
    </div>
</form>
<br />

<div>
    <table class="table table-striped border" id="myTable">
        <thead>
            <tr class="table-info">
                <th>
                    @Html.DisplayNameFor(p => p.Name)
                </th>
                <th>
                    @Html.DisplayNameFor(p => p.Price)
                </th>
                <th>
                    @Html.DisplayNameFor(p => p.Quantity)
                </th>
                <th>
                    @Html.DisplayNameFor(p => p.ProductColor)
                </th>
                <th>
                    @Html.DisplayNameFor(p => p.IsAvailable)
                </th>
                <th>
                    @Html.DisplayNameFor(p => p.ProductTypeId)
                </th>
                <th>
                    @Html.DisplayNameFor(p => p.SpecialTagId)
                </th>
                <th></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Price</td>
                    <td>@item.Quantity</td>

                    <td>@item.ProductColor</td>
                    <td>@item.IsAvailable</td>
                    <td>@item.ProductType.Name</td>
                    <td>@item.SpecialTag.Name</td>
                    <td>
                        <partial name="PartialView/CreateEditPartialView" model="@item.Id" />
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            $('#myTable').DataTable({
                dom: 'Bfrtip',  
                buttons: ['copy','csv','excel','pdf','print']
            });

            var save = '@TempData["save"]';
            var deleteMessage = '@TempData["delete"]';
            if (save && save !== '') {
                alertify.success(save);
            }
            if (deleteMessage && deleteMessage !== '') {
                alertify.error(deleteMessage);
            }
        });
    </script>
}
