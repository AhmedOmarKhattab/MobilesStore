<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title — ShopEasy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/_AuthSheet.css" />
   
</head>
<body>
    <div class="auth-shell">
        <div class="auth-panel-left">
            <div class="auth-blob blob-1"></div>
            <div class="auth-blob blob-2"></div>
            <div class="auth-blob blob-3"></div>
            <div class="auth-brand">
                <div class="auth-brand-logo"><i class="bi bi-shop-window"></i></div>
                <div class="auth-brand-name">ShopEasy</div>
                <p class="auth-brand-tagline">منصة التسوق الإلكتروني الأسرع والأكثر أماناً في المنطقة</p>
                <div class="auth-features">
                    <div class="auth-feature">
                        <div class="auth-feature-icon"><i class="bi bi-shield-fill-check"></i></div>
                        <span>ضمان أمان كامل لبياناتك</span>
                    </div>
                    <div class="auth-feature">
                        <div class="auth-feature-icon"><i class="bi bi-truck-front-fill"></i></div>
                        <span>شحن سريع لجميع المناطق</span>
                    </div>
                    <div class="auth-feature">
                        <div class="auth-feature-icon"><i class="bi bi-headset"></i></div>
                        <span>دعم فني على مدار الساعة</span>
                    </div>
                    <div class="auth-feature">
                        <div class="auth-feature-icon"><i class="bi bi-arrow-counterclockwise"></i></div>
                        <span>إرجاع مجاني خلال ٣٠ يوماً</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="auth-panel-right">
            <a asp-action="Index" asp-controller="Home" class="auth-back">
                <i class="bi bi-arrow-right"></i> العودة للمتجر
            </a>
            <div class="auth-form-wrap">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/jquery.min.js"></script>
    @await RenderSectionAsync("ValidationSection", required: false)
</body>
</html>