@model IEnumerable<Order>
@{
    ViewData["Title"] = "Index";
}

<h1>Orders</h1>

<table class="mt-3 table table-striped table-hover">
    <thead>
        <tr>
            <th>Order Numeber</th>
            <th>ClientName</th>
            <th>Email</th>
            <th>Phone Numeber</th>
            <th>Address</th>
            <th>Order Date</th>
            <th>Status</th>


        </tr>
    </thead>
    <tbody>
        @if(Model.Any())
        {
            foreach(var o in Model)
            {
                <tr>
                    <td>@o.OrderNo</td>
                    <td>@o.Name</td>
                    <td>@o.Email</td>
                    <td>@o.PhoneNo</td>

                    <td>@o.Address</td>
                    <td>@o.OrderDate</td>
                    <td>@o.Status</td>
                    <td>
                        <a asp-action="GetDetails" asp-controller="Order" class="btn btn-success" asp-route-id="@o.Id">
                            <i class="fas fa-list"></i>
                        </a>
                    </td>

                </tr>
            }
        }
    </tbody>
</table>


