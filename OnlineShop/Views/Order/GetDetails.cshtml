@model OnlineShop.Models.Order

@{
    ViewData["Title"] = "Order Details";
}

<h1 class="display-4 mb-4">Order Details</h1>

<div class="card mb-4 p-4 shadow-sm">
    <h5 class="card-title">Customer Information</h5>
    <dl class="row">
        <dt class="col-sm-3">Order No:</dt>
        <dd class="col-sm-9">@Model.OrderNo</dd>

        <dt class="col-sm-3">Name:</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Phone No:</dt>
        <dd class="col-sm-9">@Model.PhoneNo</dd>

        <dt class="col-sm-3">Email:</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">Address:</dt>
        <dd class="col-sm-9">@Model.Address</dd>

        <dt class="col-sm-3">Order Date:</dt>
        <dd class="col-sm-9">@Model.OrderDate.ToString("f")</dd>

        <dt class="col-sm-3">Status:</dt>
        <dd class="col-sm-9">@Model.Status.ToString()</dd>
    </dl>
</div>

@if (Model.Items != null && Model.Items.Any())
{
    <div class="card p-4 shadow-sm">
        <h5 class="card-title">Order Items</h5>
        <table class="table table-bordered table-hover">
            <thead class="table-light">
                <tr>
                    <th>Product</th>
                    <th>Quantity</th>
                    <th>Price (each)</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td>@item.Quantity</td>
                        <td>@item.Price.ToString("C")</td>
                        <td>@(item.Price * item.Quantity).ToString("C")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3" class="text-end">Grand Total:</th>
                    <th>
                        @Model.Items.Sum(i => i.Price * i.Quantity).ToString("C")
                    </th>
                </tr>
            </tfoot>
        </table>
    </div>
}
else
{
    <p>No items found in this order.</p>
}
